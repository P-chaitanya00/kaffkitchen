rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Contact submissions
    match /enquiries/{document} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /newsletter_subscribers/{document} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    
    // Shared admin collections for products, collections, gallery, offers, combos, and testimonials
    match /custom_products/{document} {
      allow read, write: if true;
    }
    match /deleted_products/{document} {
      allow read, write: if true;
    }
    match /custom_gallery/{document} {
      allow read, write: if true;
    }
    match /custom_collections/{document} {
      allow read, write: if true;
    }
    match /deleted_collections/{document} {
      allow read, write: if true;
    }
    match /custom_offers/{document} {
      allow read, write: if true;
    }
    match /custom_combos/{document} {
      allow read, write: if true;
    }
    match /deleted_combos/{document} {
      allow read, write: if true;
    }
    match /custom_testimonials/{document} {
      allow read, write: if true;
    }
    match /deleted_testimonials/{document} {
      allow read, write: if true;
    }
    match /admin_settings/{document} {
      allow read, write: if true;
    }
  }
}
